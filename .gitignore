</section>

<!-- BOOKING -->
<section class="booking-section" id="reservar">
  <div class="booking-inner">
    <p class="section-label">Agenda tu cita</p>
    <h2 class="section-title">Reservaciones</h2>
    <div class="booking-tabs">
      <button class="booking-tab active" onclick="setTab(this,'tattoo')">🖋 Tatuaje / Piercing</button>
      <button class="booking-tab" onclick="setTab(this,'hair')">💈 Barbería / Estilismo</button>
    </div>
    <div id="booking-form-wrap">
      <form class="booking-form" onsubmit="submitBooking(event)">
        <div class="form-row">
          <div class="form-group">
            <label>Nombre completo *</label>
            <input type="text" id="b-name" placeholder="Tu nombre" required>
          </div>
          <div class="form-group">
            <label>Teléfono / WhatsApp *</label>
            <input type="tel" id="b-phone" placeholder="+52 xxx xxx xxxx" required>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Fecha deseada *</label>
            <input type="date" id="b-date" required>
          </div>
          <div class="form-group">
            <label>Hora preferida *</label>
            <select id="b-time" required>
              <option value="">Seleccionar...</option>
              <option>10:00 AM</option><option>11:00 AM</option><option>12:00 PM</option>
              <option>1:00 PM</option><option>2:00 PM</option><option>3:00 PM</option>
              <option>4:00 PM</option><option>5:00 PM</option><option>6:00 PM</option>
            </select>
          </div>
        </div>
        <div class="form-group" id="service-group">
          <label>Servicio *</label>
          <select id="b-service" required>
            <option value="">Seleccionar...</option>
            <option>Tatuaje — Diseño personalizado</option>
            <option>Tatuaje — Flash session</option>
            <option>Tatuaje — Retoque</option>
            <option>Piercing</option>
          </select>
        </div>
        <div class="form-group">
          <label>Descripción / Referencia</label>
          <textarea id="b-desc" placeholder="Cuéntanos sobre tu diseño, zona del cuerpo, tamaño aproximado o cualquier detalle relevante..."></textarea>
        </div>
        <button type="submit" class="btn-primary booking-submit">Enviar solicitud →</button>
        <p class="booking-note">Te contactaremos en menos de 24 hrs para confirmar. Sin anticipo por ahora.</p>
      </form>
    </div>
    <div class="booking-success" id="booking-success">
      <div style="font-size:2.5rem;margin-bottom:1rem;">✓</div>
      <h3>¡Solicitud enviada!</h3>
      <p>Guillermo te contactará pronto por WhatsApp para confirmar tu cita.</p>
      <button class="btn-outline" style="margin-top:1.5rem;" onclick="resetBooking()">Hacer otra reserva</button>
    </div>
  </div>
</section>

