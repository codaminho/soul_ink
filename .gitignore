<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Soul Ink Studios — Si Buscas Perfección</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --ink: #0a0a0a;
  --smoke: #141414;
  --ash: #1e1e1e;
  --bone: #f0ebe3;
  --cream: #e8e0d4;
  --gold: #c9a84c;
  --gold-dim: #8a6f2e;
  --red: #c0392b;
  --text: #d4cfc8;
  --muted: #7a756e;
  --radius: 4px;
}
* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior: smooth; }
body { background: var(--ink); color: var(--text); font-family: 'DM Sans', sans-serif; font-size: 15px; line-height: 1.6; }

/* NAV */
nav {
  position: fixed; top: 0; width: 100%; z-index: 1000;
  background: rgba(10,10,10,0.92); backdrop-filter: blur(10px);
  border-bottom: 1px solid rgba(201,168,76,0.15);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 2.5rem; height: 64px;
}
.nav-logo { font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; letter-spacing: .1em; color: var(--bone); }
.nav-logo span { color: var(--gold); }
.nav-links { display: flex; gap: 2rem; }
.nav-links a { color: var(--muted); text-decoration: none; font-size: 13px; letter-spacing: .08em; text-transform: uppercase; transition: color .2s; }
.nav-links a:hover { color: var(--gold); }
.nav-cta { background: var(--gold); color: var(--ink); font-size: 12px; font-weight: 500; letter-spacing: .1em; text-transform: uppercase; padding: 8px 20px; border: none; cursor: pointer; border-radius: var(--radius); transition: background .2s; }
.nav-cta:hover { background: var(--cream); }
.nav-admin-btn { background: transparent; border: 1px solid rgba(201,168,76,0.4); color: var(--gold); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; padding: 7px 14px; cursor: pointer; border-radius: var(--radius); margin-left: .75rem; transition: all .2s; }
.nav-admin-btn:hover { background: rgba(201,168,76,0.1); }

/* HERO */
.hero {
  min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center;
  text-align: center; padding: 2rem;
  background: radial-gradient(ellipse at 50% 60%, rgba(201,168,76,0.06) 0%, transparent 70%);
  position: relative; overflow: hidden;
}
.hero::before {
  content: ''; position: absolute; inset: 0;
  background: repeating-linear-gradient(0deg, transparent, transparent 59px, rgba(255,255,255,0.015) 60px),
              repeating-linear-gradient(90deg, transparent, transparent 59px, rgba(255,255,255,0.015) 60px);
}
.hero-eyebrow { font-size: 11px; letter-spacing: .3em; text-transform: uppercase; color: var(--gold); margin-bottom: 1.5rem; }
.hero h1 { font-family: 'Bebas Neue', sans-serif; font-size: clamp(5rem, 15vw, 11rem); letter-spacing: -.01em; line-height: .9; color: var(--bone); }
.hero h1 span { display: block; font-family: 'DM Serif Display', serif; font-style: italic; font-size: clamp(1.5rem, 4vw, 3rem); letter-spacing: .05em; color: var(--gold); margin-top: .5rem; }
.hero-sub { margin-top: 1.5rem; font-size: 14px; color: var(--muted); letter-spacing: .05em; }
.hero-actions { display: flex; gap: 1rem; margin-top: 2.5rem; flex-wrap: wrap; justify-content: center; }
.btn-primary { background: var(--gold); color: var(--ink); font-size: 13px; font-weight: 500; letter-spacing: .1em; text-transform: uppercase; padding: 14px 32px; border: none; cursor: pointer; border-radius: var(--radius); transition: all .2s; }
.btn-primary:hover { background: var(--bone); transform: translateY(-1px); }
.btn-outline { background: transparent; color: var(--bone); font-size: 13px; letter-spacing: .1em; text-transform: uppercase; padding: 14px 32px; border: 1px solid rgba(240,235,227,0.3); cursor: pointer; border-radius: var(--radius); transition: all .2s; }
.btn-outline:hover { border-color: var(--gold); color: var(--gold); }
.hero-scroll { position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 8px; color: var(--muted); font-size: 11px; letter-spacing: .2em; text-transform: uppercase; animation: bounce 2s infinite; }
.hero-scroll::after { content: ''; display: block; width: 1px; height: 40px; background: linear-gradient(to bottom, var(--muted), transparent); }
@keyframes bounce { 0%,100% { transform: translateX(-50%) translateY(0); } 50% { transform: translateX(-50%) translateY(4px); } }

/* SERVICES */
.section { padding: 6rem 2rem; max-width: 1100px; margin: 0 auto; }
.section-label { font-size: 11px; letter-spacing: .3em; text-transform: uppercase; color: var(--gold); margin-bottom: .75rem; }
.section-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.5rem, 6vw, 4.5rem); color: var(--bone); line-height: 1; }
.services-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5px; margin-top: 3rem; background: rgba(201,168,76,0.15); }
.service-card { background: var(--smoke); padding: 2.5rem 2rem; position: relative; overflow: hidden; transition: background .3s; }
.service-card::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 2px; background: linear-gradient(90deg, transparent, var(--gold), transparent); opacity: 0; transition: opacity .3s; }
.service-card:hover { background: var(--ash); }
.service-card:hover::before { opacity: 1; }
.service-icon { font-size: 2rem; margin-bottom: 1rem; }
.service-card h3 { font-family: 'Bebas Neue', sans-serif; font-size: 1.8rem; color: var(--bone); letter-spacing: .05em; margin-bottom: .75rem; }
.service-card p { font-size: 13px; color: var(--muted); line-height: 1.7; }
.service-price { margin-top: 1.5rem; font-size: 12px; color: var(--gold); letter-spacing: .1em; text-transform: uppercase; }

/* GALLERY */
.gallery-section { background: var(--smoke); padding: 6rem 2rem; }
.gallery-inner { max-width: 1100px; margin: 0 auto; }
.gallery-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 3px; margin-top: 3rem; }
.gallery-item { position: relative; overflow: hidden; aspect-ratio: 1; background: var(--ash); }
.gallery-item img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s; filter: saturate(0.7); }
.gallery-item:hover img { transform: scale(1.05); filter: saturate(1); }
.gallery-item-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,.8) 0%, transparent 50%); opacity: 0; transition: opacity .3s; display: flex; align-items: flex-end; padding: 1.25rem; }
.gallery-item:hover .gallery-item-overlay { opacity: 1; }
.gallery-item-overlay h4 { font-family: 'Bebas Neue', sans-serif; font-size: 1.2rem; color: var(--bone); letter-spacing: .05em; }
.gallery-item-overlay p { font-size: 12px; color: var(--muted); margin-top: 2px; }
.gallery-item.featured { grid-column: span 2; }

/* BOOKING SECTION */
.booking-section { padding: 6rem 2rem; background: var(--ink); position: relative; }
.booking-section::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, var(--gold-dim), transparent); }
.booking-inner { max-width: 700px; margin: 0 auto; }
.booking-tabs { display: flex; gap: 0; margin-top: 2.5rem; border: 1px solid rgba(201,168,76,0.2); border-radius: var(--radius); overflow: hidden; }
.booking-tab { flex: 1; padding: 12px; background: transparent; border: none; color: var(--muted); font-size: 12px; letter-spacing: .1em; text-transform: uppercase; cursor: pointer; transition: all .2s; }
.booking-tab.active { background: var(--gold); color: var(--ink); font-weight: 500; }
.booking-form { margin-top: 2rem; display: flex; flex-direction: column; gap: 1rem; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.form-group { display: flex; flex-direction: column; gap: 6px; }
.form-group label { font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: var(--muted); }
.form-group input, .form-group select, .form-group textarea {
  background: var(--smoke); border: 1px solid rgba(201,168,76,0.2); color: var(--bone);
  padding: 11px 14px; font-family: 'DM Sans', sans-serif; font-size: 14px;
  border-radius: var(--radius); outline: none; transition: border-color .2s; width: 100%;
}
.form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: var(--gold); }
.form-group select option { background: var(--smoke); }
.form-group textarea { resize: vertical; min-height: 80px; }
.booking-submit { margin-top: .5rem; }
.booking-note { margin-top: 1rem; font-size: 12px; color: var(--muted); text-align: center; }
.booking-success { display: none; text-align: center; padding: 3rem; background: var(--smoke); border: 1px solid rgba(201,168,76,0.3); border-radius: var(--radius); }
.booking-success h3 { font-family: 'Bebas Neue', sans-serif; font-size: 2rem; color: var(--gold); letter-spacing: .05em; }
.booking-success p { color: var(--muted); margin-top: .5rem; font-size: 14px; }

/* CONTACT */
.contact-section { background: var(--smoke); padding: 5rem 2rem; text-align: center; }
.contact-inner { max-width: 600px; margin: 0 auto; }
.contact-links { display: flex; justify-content: center; gap: 1.5rem; margin-top: 2rem; flex-wrap: wrap; }
.contact-link { display: flex; align-items: center; gap: 8px; color: var(--muted); text-decoration: none; font-size: 13px; transition: color .2s; }
.contact-link:hover { color: var(--gold); }

/* FOOTER */
footer { background: var(--ink); border-top: 1px solid rgba(201,168,76,0.1); padding: 2rem; text-align: center; font-size: 12px; color: var(--muted); letter-spacing: .05em; }

/* ---- ADMIN OVERLAY ---- */
.admin-overlay {
  display: none; position: fixed; inset: 0; z-index: 2000;
  background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);
}
.admin-overlay.open { display: flex; }
.admin-panel {
  background: var(--smoke); width: 100%; max-width: 1000px; margin: auto;
  max-height: 90vh; overflow-y: auto; border: 1px solid rgba(201,168,76,0.25);
  border-radius: 8px; position: relative;
}
.admin-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 1.5rem 2rem; border-bottom: 1px solid rgba(201,168,76,0.15);
  position: sticky; top: 0; background: var(--smoke); z-index: 10;
}
.admin-header h2 { font-family: 'Bebas Neue', sans-serif; font-size: 1.8rem; color: var(--gold); letter-spacing: .05em; }
.admin-close { background: none; border: none; color: var(--muted); font-size: 1.5rem; cursor: pointer; padding: 4px 10px; line-height: 1; }
.admin-close:hover { color: var(--bone); }
.admin-login { padding: 3rem 2rem; max-width: 360px; margin: 0 auto; }
.admin-login h3 { font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; color: var(--bone); margin-bottom: 1.5rem; letter-spacing: .05em; text-align: center; }
.admin-login .form-group { margin-bottom: 1rem; }
.admin-content { display: none; padding: 1.5rem 2rem 2rem; }
.admin-tabs { display: flex; gap: .5rem; margin-bottom: 1.5rem; border-bottom: 1px solid rgba(255,255,255,.06); padding-bottom: .75rem; }
.admin-tab { background: none; border: none; color: var(--muted); font-size: 13px; letter-spacing: .08em; text-transform: uppercase; cursor: pointer; padding: 6px 14px; border-radius: var(--radius); transition: all .2s; }
.admin-tab.active { background: rgba(201,168,76,0.15); color: var(--gold); }
.admin-tab:hover { color: var(--bone); }
.admin-view { display: none; }
.admin-view.active { display: block; }

/* Appointments Table */
.appt-table { width: 100%; border-collapse: collapse; font-size: 13px; }
.appt-table th { text-align: left; padding: 10px 12px; font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); border-bottom: 1px solid rgba(255,255,255,.06); }
.appt-table td { padding: 12px; border-bottom: 1px solid rgba(255,255,255,.04); vertical-align: middle; }
.appt-table tr:hover td { background: rgba(255,255,255,.02); }
.badge { display: inline-block; font-size: 10px; letter-spacing: .1em; text-transform: uppercase; padding: 3px 9px; border-radius: 20px; }
.badge-pending { background: rgba(201,168,76,0.15); color: var(--gold); }
.badge-confirmed { background: rgba(39,174,96,0.15); color: #2ecc71; }
.badge-cancelled { background: rgba(192,57,43,0.15); color: #e74c3c; }
.badge-tattoo { background: rgba(142,68,173,0.15); color: #9b59b6; }
.badge-hair { background: rgba(41,128,185,0.15); color: #3498db; }
.appt-actions { display: flex; gap: 6px; }
.appt-btn { background: none; border: 1px solid rgba(255,255,255,.1); color: var(--muted); font-size: 11px; padding: 4px 10px; border-radius: 3px; cursor: pointer; transition: all .15s; }
.appt-btn:hover { border-color: var(--gold); color: var(--gold); }
.appt-btn.danger:hover { border-color: var(--red); color: var(--red); }

/* Stats */
.stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 1.5rem; }
.stat-box { background: var(--ash); border: 1px solid rgba(255,255,255,.05); border-radius: 6px; padding: 1.25rem; }
.stat-box .val { font-family: 'Bebas Neue', sans-serif; font-size: 2.2rem; color: var(--bone); letter-spacing: .02em; }
.stat-box .lbl { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: .1em; margin-top: 2px; }
.stat-box.gold-accent { border-color: rgba(201,168,76,0.3); }
.stat-box.gold-accent .val { color: var(--gold); }

/* Filter bar */
.filter-bar { display: flex; gap: .75rem; margin-bottom: 1.25rem; flex-wrap: wrap; }
.filter-select { background: var(--ash); border: 1px solid rgba(255,255,255,.08); color: var(--text); padding: 7px 12px; font-size: 12px; border-radius: var(--radius); font-family: 'DM Sans', sans-serif; }
.filter-input { background: var(--ash); border: 1px solid rgba(255,255,255,.08); color: var(--text); padding: 7px 12px; font-size: 12px; border-radius: var(--radius); font-family: 'DM Sans', sans-serif; flex: 1; min-width: 160px; outline: none; }
.filter-input:focus, .filter-select:focus { border-color: rgba(201,168,76,0.4); outline: none; }

/* Toast */
.toast { position: fixed; bottom: 2rem; right: 2rem; background: var(--gold); color: var(--ink); padding: 12px 20px; border-radius: 4px; font-size: 13px; font-weight: 500; z-index: 9999; transform: translateY(60px); opacity: 0; transition: all .3s; }
.toast.show { transform: translateY(0); opacity: 1; }

/* Admin form */
.admin-form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.admin-form-grid .full { grid-column: span 2; }

/* Calendar mini */
.calendar-mini { background: var(--ash); border: 1px solid rgba(255,255,255,.05); border-radius: 6px; padding: 1rem; }
.cal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: .75rem; }
.cal-header span { font-size: 14px; font-weight: 500; color: var(--bone); }
.cal-nav { background: none; border: none; color: var(--muted); cursor: pointer; font-size: 1rem; padding: 4px 8px; }
.cal-nav:hover { color: var(--gold); }
.cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; }
.cal-day-name { text-align: center; font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: .08em; padding: 4px 0; }
.cal-day { text-align: center; padding: 6px 2px; font-size: 12px; color: var(--muted); cursor: pointer; border-radius: 3px; transition: all .15s; }
.cal-day:hover { background: rgba(201,168,76,0.15); color: var(--gold); }
.cal-day.today { color: var(--gold); font-weight: 500; }
.cal-day.has-appt { position: relative; color: var(--bone); }
.cal-day.has-appt::after { content: ''; position: absolute; bottom: 2px; left: 50%; transform: translateX(-50%); width: 4px; height: 4px; border-radius: 50%; background: var(--gold); }
.cal-day.empty { cursor: default; }
.cal-day.selected { background: var(--gold); color: var(--ink); }

/* Responsive */
@media (max-width: 768px) {
  .gallery-grid { grid-template-columns: 1fr 1fr; }
  .gallery-item.featured { grid-column: span 2; }
  .form-row { grid-template-columns: 1fr; }
  .stats-grid { grid-template-columns: 1fr 1fr; }
  .admin-form-grid { grid-template-columns: 1fr; }
  .admin-form-grid .full { grid-column: span 1; }
  .nav-links { display: none; }
}
</style>
</head>
<body>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<!-- NAV -->
<nav>
  <div class="nav-logo">Soul <span>Ink</span> Studios</div>
  <div class="nav-links">
    <a href="#servicios">Servicios</a>
    <a href="#galeria">Galería</a>
    <a href="#reservar">Reservar</a>
    <a href="#contacto">Contacto</a>
  </div>
  <div style="display:flex;align-items:center;gap:.5rem;">
    <button class="nav-cta" onclick="scrollTo('#reservar')">Agendar cita</button>
    <button class="nav-admin-btn" onclick="openAdmin()">Admin ⚙</button>
  </div>
</nav>

<!-- HERO -->
<section class="hero" id="inicio">
  <div style="position:relative;z-index:1;">
    <p class="hero-eyebrow">Guillermo Morales — Hidalgo del Parral, México</p>
    <h1>Soul Ink<span>Si Buscas Perfección</span></h1>
    <p class="hero-sub">Tattoo · Piercing · Barbería & Estilismo</p>
    <div class="hero-actions">
      <button class="btn-primary" onclick="scrollTo('#reservar')">Reservar cita</button>
      <button class="btn-outline" onclick="scrollTo('#galeria')">Ver galería</button>
    </div>
  </div>
  <div class="hero-scroll">Scroll</div>
</section>

<!-- SERVICIOS -->
<section class="section" id="servicios">
  <p class="section-label">Lo que hacemos</p>
  <h2 class="section-title">Servicios</h2>
  <div class="services-grid">
    <div class="service-card">
      <div class="service-icon">🖋</div>
      <h3>Tatuajes</h3>
      <p>Diseños personalizados, flash sessions, linea fina, blackwork, color y retoques. Cada pieza es única y diseñada con libertad creativa.</p>
      <div class="service-price">Desde $800 MXN · Consulta gratuita</div>
    </div>
    <div class="service-card">
      <div class="service-icon">💈</div>
      <h3>Barbería</h3>
      <p>Cortes clásicos y modernos, arreglo de barba, afeitado a navaja, tratamientos capilares. Estilo que define tu personalidad.</p>
      <div class="service-price">Desde $150 MXN · Sin cita disponible</div>
    </div>
    <div class="service-card">
      <div class="service-icon">✂️</div>
      <h3>Estilismo</h3>
      <p>Coloración, mechas, keratina, cortes para todos los géneros. Transformaciones completas con productos de primera calidad.</p>
      <div class="service-price">Desde $300 MXN · Cita previa</div>
    </div>
    <div class="service-card">
      <div class="service-icon">💎</div>
      <h3>Piercing</h3>
      <p>Perforaciones profesionales con joyería de titanio implant-grade. Oreja, nariz, labio, tragus, helix y más.</p>
      <div class="service-price">Desde $350 MXN incl. joyería</div>
    </div>
  </div>
</section>

<!-- GALERÍA -->
<section class="gallery-section" id="galeria">
  <div class="gallery-inner">
    <p class="section-label">Nuestro trabajo</p>
    <h2 class="section-title">Galería</h2>
    <div class="gallery-grid">
      <div class="gallery-item featured">
        <img src="https://scontent-phx1-1.cdninstagram.com/v/t51.71878-15/619657201_771092238719488_6308603377933808127_n.jpg?stp=c0.249.640.640a_dst-jpg_e15_tt6&_nc_ht=scontent-phx1-1.cdninstagram.com&_nc_cat=104&_nc_oc=Q6cZ2QFKoLD2I3EzdunimC1nQp7_b2CHvs-R5dpB81pRUFWJbLfe2X4locLNpP4IlNWR5tg&_nc_ohc=fNyA5IdPOpIQ7kNvwGiQhVL&_nc_gid=U86q8XOhK6RZa_0JYwJ3lg&edm=AOQ1c0wBAAAA&ccb=7-5&oh=00_AfyXNkPHN_hQc41BZtRlpD00vOtFzxhopz8F-H5aPVcqnw&oe=69B1193D&_nc_sid=8b3546" alt="Proyecto completo" loading="lazy">
        <div class="gallery-item-overlay"><div><h4>Proyecto completo</h4><p>Proyecto de más de 2 años con libertad creativa</p></div></div>
      </div>
      <div class="gallery-item">
        <img src="https://scontent-phx1-1.cdninstagram.com/v/t51.82787-15/612663558_18413030572186802_4149880888946518036_n.jpg?stp=c0.237.610.610a_dst-jpg_e15_tt6&_nc_ht=scontent-phx1-1.cdninstagram.com&_nc_cat=102&_nc_oc=Q6cZ2QFKoLD2I3EzdunimC1nQp7_b2CHvs-R5dpB81pRUFWJbLfe2X4locLNpP4IlNWR5tg&_nc_ohc=WsTmXBJw6vsQ7kNvwGvn8AH&_nc_gid=U86q8XOhK6RZa_0JYwJ3lg&edm=AOQ1c0wBAAAA&ccb=7-5&oh=00_AfyERIMhxiQNvws213_VGKRpBCbWkkxm3eo3FExYcPP2jA&oe=69B12128&_nc_sid=8b3546" alt="Flor del Infierno" loading="lazy">
        <div class="gallery-item-overlay"><div><h4>Flor del Infierno</h4><p>Lirios araña rojos con líneas abstractas</p></div></div>
      </div>
      <div class="gallery-item">
        <img src="https://scontent-phx1-1.cdninstagram.com/v/t15.5256-10/616074792_1457489239331973_4352312594922850685_n.jpg?stp=c0.280.720.720a_dst-jpg_e15_s640x640_tt6&_nc_ht=scontent-phx1-1.cdninstagram.com&_nc_cat=109&_nc_oc=Q6cZ2QFKoLD2I3EzdunimC1nQp7_b2CHvs-R5dpB81pRUFWJbLfe2X4locLNpP4IlNWR5tg&_nc_ohc=TZ4c2CuHm44Q7kNvwHnNE8M&_nc_gid=U86q8XOhK6RZa_0JYwJ3lg&edm=AOQ1c0wBAAAA&ccb=7-5&oh=00_Afzog_p4oIasbh1etY4eudSO9r9YTXXnyx0CjEGJARbM0Q&oe=69B11A02&_nc_sid=8b3546" alt="Soul Ink Studios" loading="lazy">
        <div class="gallery-item-overlay"><div><h4>Soul Ink Studio's</h4><p>Otro día en el estudio</p></div></div>
      </div>
      <div class="gallery-item">
        <img src="https://scontent-phx1-1.cdninstagram.com/v/t15.5256-10/631405255_851936021198023_2657137489967577917_n.jpg?stp=c0.422.1076.1076a_dst-jpg_e15_s640x640_tt6&_nc_ht=scontent-phx1-1.cdninstagram.com&_nc_cat=107&_nc_oc=Q6cZ2QFKoLD2I3EzdunimC1nQp7_b2CHvs-R5dpB81pRUFWJbLfe2X4locLNpP4IlNWR5tg&_nc_ohc=pEEE1URXy3EQ7kNvwFVLx6M&_nc_gid=U86q8XOhK6RZa_0JYwJ3lg&edm=AOQ1c0wBAAAA&ccb=7-5&oh=00_Afyu8kFV5L8i3QO_l_8UqiK-oz2E4ws9DRwHAoQgqGeRZQ&oe=69B13756&_nc_sid=8b3546" alt="Baúl de Recuerdos" loading="lazy">
        <div class="gallery-item-overlay"><div><h4>Baúl de Recuerdos</h4><p>5 años de estas piezas del baúl</p></div></div>
      </div>
      <div class="gallery-item">
        <img src="https://scontent-phx1-1.cdninstagram.com/v/t15.5256-10/628632595_25995968043370224_6043588131285018280_n.jpg?stp=c0.280.720.720a_dst-jpg_e15_s640x640_tt6&_nc_ht=scontent-phx1-1.cdninstagram.com&_nc_cat=100&_nc_oc=Q6cZ2QFKoLD2I3EzdunimC1nQp7_b2CHvs-R5dpB81pRUFWJbLfe2X4locLNpP4IlNWR5tg&_nc_ohc=5kdVD75ZDZUQ7kNvwHq8Qze&_nc_gid=U86q8XOhK6RZa_0JYwJ3lg&edm=AOQ1c0wBAAAA&ccb=7-5&oh=00_AfxLd90txjKNzYmxj1iZZ3Y7WVi3Xqhl9ueFStbKlvOqJQ&oe=69B1356B&_nc_sid=8b3546" alt="Dragon Ball" loading="lazy">
        <div class="gallery-item-overlay"><div><h4>Dragon Ball</h4><p>Coleccionista · línea fina</p></div></div>
