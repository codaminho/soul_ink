      <div class="gallery-item">
        <img src="https://scontent-phx1-1.cdninstagram.com/v/t15.5256-10/608354817_2057790228375496_7717203589262957434_n.jpg?stp=c0.280.720.720a_dst-jpg_e15_s640x640_tt6&_nc_ht=scontent-phx1-1.cdninstagram.com&_nc_cat=104&_nc_oc=Q6cZ2QFKoLD2I3EzdunimC1nQp7_b2CHvs-R5dpB81pRUFWJbLfe2X4locLNpP4IlNWR5tg&_nc_ohc=nAOox0gEzCUQ7kNvwFRbfzT&_nc_gid=U86q8XOhK6RZa_0JYwJ3lg&edm=AOQ1c0wBAAAA&ccb=7-5&oh=00_AfyYshGJFwFdOPCvGyVh2QGtY0b2uiKZ-MDOfaXNWidV8g&oe=69B11A6C&_nc_sid=8b3546" alt="Colores Vivos" loading="lazy">
        <div class="gallery-item-overlay"><div><h4>Colores Vivos</h4><p>Afilando el colmillo</p></div></div>
      </div>
    </div>
