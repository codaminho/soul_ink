</footer>

<!-- ===== ADMIN OVERLAY ===== -->
<div class="admin-overlay" id="adminOverlay">
  <div class="admin-panel">
    <div class="admin-header">
      <h2>Admin — Soul Ink Studios</h2>
      <button class="admin-close" onclick="closeAdmin()">✕</button>
    </div>

    <!-- LOGIN -->
    <div class="admin-login" id="adminLogin">
      <h3>Acceso administrador</h3>
      <div class="form-group"><label>Usuario</label><input type="text" id="admin-user" placeholder="admin"></div>
      <div class="form-group"><label>Contraseña</label><input type="password" id="admin-pass" placeholder="••••••"></div>
      <button class="btn-primary" style="width:100%;margin-top:.5rem;" onclick="doLogin()">Entrar →</button>
      <p style="font-size:11px;color:var(--muted);text-align:center;margin-top:1rem;">Demo: admin / admin123</p>
    </div>

    <!-- CONTENT -->
    <div class="admin-content" id="adminContent">
      <div class="admin-tabs">
        <button class="admin-tab active" onclick="switchAdminTab(this,'dashboard')">Dashboard</button>
        <button class="admin-tab" onclick="switchAdminTab(this,'appointments')">Citas</button>
        <button class="admin-tab" onclick="switchAdminTab(this,'calendar')">Calendario</button>
        <button class="admin-tab" onclick="switchAdminTab(this,'new-appt')">Nueva cita</button>
      </div>

      <!-- DASHBOARD -->
      <div class="admin-view active" id="view-dashboard">
        <div class="stats-grid">
          <div class="stat-box gold-accent"><div class="val" id="stat-total">0</div><div class="lbl">Total citas</div></div>
          <div class="stat-box"><div class="val" id="stat-pending" style="color:#c9a84c;">0</div><div class="lbl">Pendientes</div></div>
          <div class="stat-box"><div class="val" id="stat-confirmed" style="color:#2ecc71;">0</div><div class="lbl">Confirmadas</div></div>
          <div class="stat-box"><div class="val" id="stat-today">0</div><div class="lbl">Hoy</div></div>
        </div>
        <div style="background:var(--ash);border-radius:6px;padding:1.25rem;">
          <p style="font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:.75rem;">Próximas citas</p>
          <div id="upcoming-list"></div>
        </div>
      </div>

      <!-- CITAS -->
      <div class="admin-view" id="view-appointments">
        <div class="filter-bar">
          <input class="filter-input" id="search-appt" placeholder="Buscar por nombre o teléfono..." oninput="renderTable()">
          <select class="filter-select" id="filter-type" onchange="renderTable()">
            <option value="">Todos los servicios</option>
            <option value="tattoo">Tatuaje / Piercing</option>
            <option value="hair">Barbería / Estilismo</option>
          </select>
          <select class="filter-select" id="filter-status" onchange="renderTable()">
            <option value="">Todos los estados</option>
            <option value="pending">Pendiente</option>
            <option value="confirmed">Confirmada</option>
            <option value="cancelled">Cancelada</option>
          </select>
        </div>
        <div style="overflow-x:auto;">
          <table class="appt-table">
            <thead>
              <tr>
                <th>Cliente</th>
                <th>Servicio</th>
                <th>Fecha</th>
                <th>Hora</th>
                <th>Estado</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody id="appt-tbody"></tbody>
          </table>
        </div>
      </div>

      <!-- CALENDAR -->
      <div class="admin-view" id="view-calendar">
        <div style="display:grid;grid-template-columns:280px 1fr;gap:1.5rem;">
          <div>
            <div class="calendar-mini" id="calMini"></div>
            <div style="margin-top:1rem;font-size:12px;color:var(--muted);">· Puntos dorados = citas agendadas</div>
          </div>
          <div>
            <p style="font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:.75rem;" id="cal-day-label">Selecciona un día</p>
            <div id="cal-day-appts"></div>
          </div>
        </div>
      </div>

      <!-- NUEVA CITA -->
      <div class="admin-view" id="view-new-appt">
        <form class="admin-form-grid" onsubmit="addManualAppt(event)">
          <div class="form-group"><label>Nombre *</label><input type="text" id="na-name" placeholder="Cliente" required></div>
          <div class="form-group"><label>Teléfono *</label><input type="tel" id="na-phone" placeholder="+52..." required></div>
          <div class="form-group"><label>Fecha *</label><input type="date" id="na-date" required></div>
          <div class="form-group"><label>Hora *</label>
            <select id="na-time" required>
              <option value="">Hora...</option>
              <option>10:00 AM</option><option>11:00 AM</option><option>12:00 PM</option>
              <option>1:00 PM</option><option>2:00 PM</option><option>3:00 PM</option>
              <option>4:00 PM</option><option>5:00 PM</option><option>6:00 PM</option>
            </select>
          </div>
          <div class="form-group"><label>Tipo</label>
            <select id="na-type">
              <option value="tattoo">Tatuaje / Piercing</option>
              <option value="hair">Barbería / Estilismo</option>
            </select>
          </div>
          <div class="form-group"><label>Estado</label>
            <select id="na-status">
              <option value="pending">Pendiente</option>
              <option value="confirmed">Confirmada</option>
            </select>
          </div>
          <div class="form-group full"><label>Notas</label><textarea id="na-notes" placeholder="Descripción del servicio..."></textarea></div>
          <div class="full"><button type="submit" class="btn-primary">Agregar cita →</button></div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
// ---- DATA ----
const today = new Date();
const fmt = d => d.toISOString().split('T')[0];
const todayStr = fmt(today);

function daysFromNow(n) {
  const d = new Date(today); d.setDate(d.getDate()+n); return fmt(d);
}

let appointments = [
  { id:1, name:'Carlos Méndez', phone:'+52 614 123 4567', date: daysFromNow(1), time:'11:00 AM', type:'tattoo', service:'Tatuaje — Diseño personalizado', status:'confirmed', notes:'Manga completa, referencia enviada por IG' },
  { id:2, name:'Sofía Ramos', phone:'+52 614 987 6543', date: daysFromNow(2), time:'3:00 PM', type:'hair', service:'Coloración — mechas', status:'pending', notes:'Mechas platinadas, cabello largo' },
  { id:3, name:'Marco Ávila', phone:'+52 648 555 0101', date: daysFromNow(0), time:'10:00 AM', type:'tattoo', service:'Piercing', status:'confirmed', notes:'Helix oreja derecha' },
  { id:4, name:'Valentina Cruz', phone:'+52 614 200 3344', date: daysFromNow(3), time:'2:00 PM', type:'tattoo', service:'Tatuaje — Flash session', status:'pending', notes:'Diseño pequeño, muñeca' },
  { id:5, name:'Rodrigo Peña', phone:'+52 648 777 8899', date: daysFromNow(0), time:'4:00 PM', type:'hair', service:'Corte + barba', status:'confirmed', notes:'' },
  { id:6, name:'Andrea López', phone:'+52 614 333 2211', date: daysFromNow(5), time:'1:00 PM', type:'tattoo', service:'Tatuaje — Retoque', status:'cancelled', notes:'Retoque en tatuaje de hace 1 año' },
];
let nextId = 7;

// Booking tab state
let activeBookingType = 'tattoo';
const hairServices = ['Corte de cabello','Arreglo de barba','Coloración','Mechas / Highlights','Keratina','Corte + barba'];
const tattooServices = ['Tatuaje — Diseño personalizado','Tatuaje — Flash session','Tatuaje — Retoque','Piercing'];

function setTab(btn, type) {
  document.querySelectorAll('.booking-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  activeBookingType = type;
  const sel = document.getElementById('b-service');
  sel.innerHTML = '<option value="">Seleccionar...</option>';
  const svcs = type === 'hair' ? hairServices : tattooServices;
  svcs.forEach(s => { const o = document.createElement('option'); o.text = s; sel.appendChild(o); });
}

function submitBooking(e) {
  e.preventDefault();
  const appt = {
    id: nextId++,
    name: document.getElementById('b-name').value,
    phone: document.getElementById('b-phone').value,
    date: document.getElementById('b-date').value,
    time: document.getElementById('b-time').value,
    type: activeBookingType,
    service: document.getElementById('b-service').value,
    status: 'pending',
    notes: document.getElementById('b-desc').value
  };
  appointments.push(appt);
  document.getElementById('booking-form-wrap').style.display = 'none';
  document.getElementById('booking-success').style.display = 'block';
  updateStats();
}

function resetBooking() {
  document.getElementById('booking-form-wrap').style.display = 'block';
  document.getElementById('booking-success').style.display = 'none';
  document.querySelector('.booking-form').reset();
}

function scrollTo(sel) {
  document.querySelector(sel).scrollIntoView({behavior:'smooth'});
}

// ---- ADMIN ----
let isLoggedIn = false;
function openAdmin() {
  document.getElementById('adminOverlay').classList.add('open');
  if(isLoggedIn) {
    document.getElementById('adminLogin').style.display = 'none';
    document.getElementById('adminContent').style.display = 'block';
    updateStats(); renderTable(); renderCalendar(); renderUpcoming();
  }
}
function closeAdmin() { document.getElementById('adminOverlay').classList.remove('open'); }
document.getElementById('adminOverlay').addEventListener('click', e => { if(e.target===document.getElementById('adminOverlay')) closeAdmin(); });

function doLogin() {
  const u = document.getElementById('admin-user').value;
  const p = document.getElementById('admin-pass').value;
  if(u === 'admin' && p === 'admin123') {
    isLoggedIn = true;
    document.getElementById('adminLogin').style.display = 'none';
    document.getElementById('adminContent').style.display = 'block';
    updateStats(); renderTable(); renderCalendar(); renderUpcoming();
    toast('Bienvenido, Guillermo 👋');
  } else {
    toast('Credenciales incorrectas'); 
  }
}

function switchAdminTab(btn, view) {
  document.querySelectorAll('.admin-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.admin-view').forEach(v => v.classList.remove('active'));
  document.getElementById('view-'+view).classList.add('active');
  if(view==='appointments') renderTable();
  if(view==='calendar') renderCalendar();
  if(view==='dashboard') { updateStats(); renderUpcoming(); }
}

function updateStats() {
  document.getElementById('stat-total').textContent = appointments.length;
  document.getElementById('stat-pending').textContent = appointments.filter(a=>a.status==='pending').length;
  document.getElementById('stat-confirmed').textContent = appointments.filter(a=>a.status==='confirmed').length;
  document.getElementById('stat-today').textContent = appointments.filter(a=>a.date===todayStr).length;
}

function renderUpcoming() {
  const sorted = [...appointments].filter(a=>a.status!=='cancelled'&&a.date>=todayStr).sort((a,b)=>a.date.localeCompare(b.date)).slice(0,5);
  const el = document.getElementById('upcoming-list');
  if(!sorted.length){ el.innerHTML='<p style="color:var(--muted);font-size:13px;">Sin citas próximas</p>'; return; }
  el.innerHTML = sorted.map(a => `
    <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid rgba(255,255,255,.04);">
      <div>
        <p style="font-size:14px;color:var(--bone);font-weight:500;">${a.name}</p>
        <p style="font-size:12px;color:var(--muted);">${a.service}</p>
      </div>
      <div style="text-align:right;">
        <p style="font-size:12px;color:var(--gold);">${formatDate(a.date)}</p>
        <p style="font-size:12px;color:var(--muted);">${a.time}</p>
      </div>
    </div>`).join('');
}

function formatDate(d) {
  if(!d) return '';
  const [y,m,day] = d.split('-');
  const months = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
  return `${parseInt(day)} ${months[parseInt(m)-1]} ${y}`;
}

function renderTable() {
  const search = (document.getElementById('search-appt')||{value:''}).value.toLowerCase();
  const typeF = (document.getElementById('filter-type')||{value:''}).value;
  const statusF = (document.getElementById('filter-status')||{value:''}).value;
  let data = appointments.filter(a => {
    if(search && !a.name.toLowerCase().includes(search) && !a.phone.includes(search)) return false;
    if(typeF && a.type !== typeF) return false;
    if(statusF && a.status !== statusF) return false;
    return true;
  }).sort((a,b)=>a.date.localeCompare(b.date));
  const tbody = document.getElementById('appt-tbody');
  tbody.innerHTML = data.map(a => `
    <tr>
      <td>
        <p style="color:var(--bone);font-weight:500;">${a.name}</p>
        <p style="font-size:12px;color:var(--muted);">${a.phone}</p>
      </td>
      <td>
        <span class="badge badge-${a.type}">${a.type==='tattoo'?'Tattoo':'Cabello'}</span>
        <p style="font-size:12px;color:var(--muted);margin-top:3px;">${a.service}</p>
      </td>
      <td>${formatDate(a.date)}</td>
      <td>${a.time}</td>
      <td><span class="badge badge-${a.status}">${{pending:'Pendiente',confirmed:'Confirmada',cancelled:'Cancelada'}[a.status]}</span></td>
      <td>
        <div class="appt-actions">
          ${a.status==='pending'?`<button class="appt-btn" onclick="changeStatus(${a.id},'confirmed')">✓ Confirmar</button>`:''}
          ${a.status!=='cancelled'?`<button class="appt-btn danger" onclick="changeStatus(${a.id},'cancelled')">✕ Cancelar</button>`:''}
          <button class="appt-btn danger" onclick="deleteAppt(${a.id})">🗑</button>
        </div>
      </td>
    </tr>`).join('');
}

function changeStatus(id, status) {
  const a = appointments.find(x=>x.id===id);
  if(a){ a.status=status; renderTable(); updateStats(); renderUpcoming(); toast('Estado actualizado'); }
}

function deleteAppt(id) {
  appointments = appointments.filter(x=>x.id!==id);
  renderTable(); updateStats(); renderUpcoming(); renderCalendar(); toast('Cita eliminada');
}

// Calendar
let calYear = today.getFullYear(), calMonth = today.getMonth();
function renderCalendar() {
  const days = ['D','L','M','Mi','J','V','S'];
  const months = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
  const firstDay = new Date(calYear, calMonth, 1).getDay();
  const daysInMonth = new Date(calYear, calMonth+1, 0).getDate();
  const apptDates = new Set(appointments.map(a=>a.date));
  let html = `<div class="cal-header">
    <button class="cal-nav" onclick="changeCalMonth(-1)">‹</button>
    <span>${months[calMonth]} ${calYear}</span>
    <button class="cal-nav" onclick="changeCalMonth(1)">›</button>
  </div>
  <div class="cal-grid">
    ${days.map(d=>`<div class="cal-day-name">${d}</div>`).join('')}
    ${Array(firstDay).fill('<div class="cal-day empty"></div>').join('')}
    ${Array.from({length:daysInMonth},(_,i)=>{
      const d = i+1;
      const ds = `${calYear}-${String(calMonth+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
      const cls = ['cal-day', ds===todayStr?'today':'', apptDates.has(ds)?'has-appt':''].filter(Boolean).join(' ');
      return `<div class="${cls}" onclick="showDayAppts('${ds}')">${d}</div>`;
    }).join('')}
  </div>`;
  document.getElementById('calMini').innerHTML = html;
}

function changeCalMonth(dir) { calMonth+=dir; if(calMonth>11){calMonth=0;calYear++;}if(calMonth<0){calMonth=11;calYear--;} renderCalendar(); }

function showDayAppts(ds) {
  document.querySelectorAll('.cal-day').forEach(d=>d.classList.remove('selected'));
  event.target.classList.add('selected');
  const dayAppts = appointments.filter(a=>a.date===ds);
  document.getElementById('cal-day-label').textContent = formatDate(ds) || 'Sin fecha';
  const el = document.getElementById('cal-day-appts');
  if(!dayAppts.length){ el.innerHTML='<p style="color:var(--muted);font-size:13px;">Sin citas este día.</p>'; return; }
  el.innerHTML = dayAppts.map(a=>`
    <div style="background:var(--ash);border-radius:6px;padding:1rem;margin-bottom:.75rem;border-left:2px solid ${a.type==='tattoo'?'#9b59b6':'#3498db'};">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;">
        <div>
          <p style="font-weight:500;color:var(--bone);">${a.name}</p>
          <p style="font-size:12px;color:var(--muted);">${a.service}</p>
          ${a.notes?`<p style="font-size:12px;color:var(--muted);margin-top:4px;font-style:italic;">${a.notes}</p>`:''}
        </div>
        <div style="text-align:right;">
          <p style="color:var(--gold);font-size:13px;">${a.time}</p>
          <span class="badge badge-${a.status}" style="margin-top:4px;">${{pending:'Pendiente',confirmed:'Confirmada',cancelled:'Cancelada'}[a.status]}</span>
        </div>
      </div>
    </div>`).join('');
}

function addManualAppt(e) {
  e.preventDefault();
  appointments.push({
    id: nextId++,
    name: document.getElementById('na-name').value,
    phone: document.getElementById('na-phone').value,
    date: document.getElementById('na-date').value,
    time: document.getElementById('na-time').value,
    type: document.getElementById('na-type').value,
    service: document.getElementById('na-type').value === 'tattoo' ? 'Tatuaje personalizado' : 'Servicio de cabello',
    status: document.getElementById('na-status').value,
    notes: document.getElementById('na-notes').value
  });
  e.target.reset();
  updateStats(); renderTable(); renderCalendar(); renderUpcoming();
  toast('Cita agregada correctamente ✓');
  switchAdminTab(document.querySelectorAll('.admin-tab')[1], 'appointments');
  document.querySelectorAll('.admin-tab').forEach((b,i)=>b.classList.toggle('active',i===1));
}

function toast(msg) {
  const t = document.getElementById('toast'); t.textContent=msg; t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), 2800);
}

// Set min date on booking form
document.getElementById('b-date').min = todayStr;

// Initialize tab
setTab(document.querySelector('.booking-tab'), 'tattoo');
</script>
</body>
</html>
